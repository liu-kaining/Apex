# FMP Premium API key — https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_api_key_here

# SEC EDGAR User-Agent (required by SEC fair access policy)
SEC_USER_AGENT=Apex_Data_Bot/1.0 (contact@thetamind.ai)

# Cloudflare R2 (S3-compatible) — static JSON data lake
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=apex-data
# Object key prefix (optional, default v1/ → v1/feed_today.json)
R2_KEY_PREFIX=v1/
